    "test:e2e:debug": "playwright test --debug",
    "test:app": "node scripts/app-system-audit.mjs",
    "mobile:sync": "npm run build && npx cap sync android",
    "mobile:android": "npx cap open android",
    "mobile:build": "npm run build && npx cap sync android",
    "start": "vite preview --port 3000"
  },
