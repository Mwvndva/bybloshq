# Copy to android/keystore.properties (git-ignored) and fill in your upload key.
# Generate the key once with:
#   keytool -genkey -v -keystore byblos-upload.jks -keyalg RSA -keysize 2048 -validity 10000 -alias byblos-upload
# Then keep byblos-upload.jks + these passwords backed up somewhere safe —
# losing them means you can no longer publish updates.
storeFile=../byblos-upload.jks
storePassword=CHANGE_ME
keyAlias=byblos-upload
keyPassword=CHANGE_ME
