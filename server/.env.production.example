# BYBLOS Production Environment Template — Standardized
# Copy this to .env (or .env.production) on your production server

NODE_ENV=production
PORT=3002
APP_NAME=Byblos

# ─── Database ─────────────────────────────────────────────────────────────────
# Connection string (DATABASE_URL) is deprecated in favor of individual vars
DB_HOST=localhost
DB_PORT=5432
DB_USER=byblos
DB_PASSWORD=your_password
DB_NAME=bybloshq

# ─── Security & Auth ──────────────────────────────────────────────────────────
# JWT_SECRET: Generate with: openssl rand -base64 64
JWT_SECRET=your_ultra_secure_jwt_secret_here
JWT_REFRESH_SECRET=your_ultra_secure_refresh_secret_here
JWT_EXPIRES_IN=24h

# ─── Payment Gateway (Payd v2) ────────────────────────────────────────────────
PAYMENT_PROVIDER=paystack
PAYOUT_PROVIDER=paystack
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_BASE_URL=https://api.paystack.co
PAYSTACK_WEBHOOK_IPS=52.31.139.75,52.49.173.169,52.214.14.220
PAYSTACK_WEBHOOK_URL=https://bybloshq.space/api/webhooks/paystack
PAYSTACK_PAYMENT_CALLBACK_URL=https://bybloshq.space/api/webhooks/paystack
PAYSTACK_PAYOUT_CALLBACK_URL=https://bybloshq.space/api/webhooks/paystack

# ─── Resend SMTP ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USERNAME=resend
EMAIL_PASSWORD=re_YOUR_RESEND_API_KEY_HERE
EMAIL_FROM_EMAIL=no-reply@bybloshq.space
EMAIL_FROM_NAME=Byblos

# ─── Email verification settings ─────────────────────────────────────────────
# How long (hours) before a verification link expires
EMAIL_VERIFICATION_EXPIRES_HOURS=24

# ─── Legacy Email (Hostinger) — Fallback ────────────────────────────────────
# EMAIL_HOST=smtp.hostinger.com
# EMAIL_PORT=465
# EMAIL_SECURE=true
# EMAIL_USERNAME=no-reply@bybloshq.space
# EMAIL_PASSWORD=your_smtp_password
# EMAIL_FROM_NAME=Byblos
# EMAIL_FROM_EMAIL=no-reply@bybloshq.space

# ─── Infrastructure ──────────────────────────────────────────────────────────
FRONTEND_URL=https://bybloshq.space
BACKEND_URL=https://api.bybloshq.space
ALLOWED_ORIGINS=https://bybloshq.space,https://www.bybloshq.space

# Cloudinary (Required for production image storage)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis: Fallback to memory if not set
REDIS_URL=redis://localhost:6379

# ─── Feature Flags ────────────────────────────────────────────────────────────
ENABLE_PAYMENT_CRON=true
ENABLE_ORDER_DEADLINE_CRON=true
ENABLE_PAYOUT_RECONCILIATION_CRON=true
ENABLE_REFERRAL_CRON=true
ENABLE_COMPLETION_RETRY_CRON=true

# ─── WhatsApp / Logistics ─────────────────────────────────────────────────────
COURIER_WHATSAPP_NUMBER=0748137819
DROPOFF_LOCATION="Dynamic Mall, Tom Mboya St, Nairobi | Shop SL 32"
LOGISTICS_HUB_LABEL=MZIGO EGO
LOGISTICS_HUB_ADDRESS="Dynamic Mall, Tom Mboya St, Nairobi | Shop SL 32"
LOGISTICS_HUB_LATITUDE=-1.2836
LOGISTICS_HUB_LONGITUDE=36.8249

# Shared rate for buyer door delivery and seller pickup quotes.
LOGISTICS_RATE_KES_PER_KM=40
