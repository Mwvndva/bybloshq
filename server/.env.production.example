# Byblos Production Environment Template
# Copy this to .env (or .env.production) on your production VM

NODE_ENV=production
PORT=3002

# ─── Database ─────────────────────────────────────────────────────────────────
# Either providing a full URL (recommended)
DATABASE_URL=postgres://user:password@host:port/dbname
# ...or individual parts
# DB_HOST=localhost
# DB_USER=byblos
# DB_PASSWORD=your_password
# DB_NAME=bybloshq

# ─── Security & Auth ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_32_plus_char_secret
JWT_REFRESH_SECRET=your_32_plus_char_refresh_secret

# CSRF Protection — any long random string
# REQUIRED in production
CSRF_SECRET=your_long_random_csrf_secret

# ─── DRM (Digital Rights Management) ──────────────────────────────────────────
# Master key for .bybx file encryption/decryption
# MUST be 64-character hex string (32 bytes)
# Generate with: openssl rand -hex 32
DRM_MASTER_KEY=your_64_char_hex_key

# ─── Payment Gateway (Payd) ───────────────────────────────────────────────────
PAYD_USERNAME=your_username
PAYD_PASSWORD=your_password
PAYD_NETWORK_CODE=your_network_code
PAYD_CHANNEL_ID=your_channel_id

# ─── URLs ─────────────────────────────────────────────────────────────────────
# No trailing slashes
FRONTEND_URL=https://bybloshq.space
BACKEND_URL=https://bybloshq.space/api
PAYD_CALLBACK_URL=https://bybloshq.space/api/callbacks/payd

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Features ─────────────────────────────────────────────────────────────────
# Set to 'false' to disable specific crons
ENABLE_PAYMENT_CRON=true
ENABLE_ORDER_DEADLINE_CRON=true
ENABLE_PAYOUT_RECONCILIATION_CRON=true
ENABLE_REFERRAL_CRON=true
ENABLE_COMPLETION_RETRY_CRON=true

# ─── Redis (Optional) ────────────────────────────────────────────────────────
# Fallback to memory if not set
# REDIS_URL=redis://localhost:6379

# ─── Email (SMTP/Hostinger) ──────────────────────────────────────────────────
# Supporting both EMAIL_* and SMTP_* prefixes
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=your_email@bybloshq.space
EMAIL_PASS=your_email_password
EMAIL_FROM=Byblos <no-reply@bybloshq.space>
