<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Payment Receipt - <%= orderNumber %>
    </title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

        body {
            font-family: 'Inter', sans-serif;
            line-height: 1.6;
            color: #1a202c;
            background-color: #f7fafc;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 600px;
            margin: 0 auto;
            padding: 20px;
        }

        .header {
            text-align: center;
            padding: 30px 20px;
            background: #000;
            color: white;
            border-radius: 8px 8px 0 0;
        }

        .header h1 {
            margin: 0;
            font-size: 24px;
            font-weight: 700;
        }

        .content {
            background: #ffffff;
            border-radius: 0 0 8px 8px;
            padding: 30px;
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }

        .receipt-header {
            text-align: center;
            margin-bottom: 25px;
            padding-bottom: 20px;
            border-bottom: 2px dashed #e2e8f0;
        }

        .receipt-header h2 {
            margin: 0;
            color: #000;
            font-size: 20px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .order-details {
            margin: 25px 0;
            border: 1px solid #e2e8f0;
            border-radius: 8px;
            padding: 20px;
            background: #f8fafc;
        }

        .item-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #edf2f7;
        }

        .item-row:last-child {
            border-bottom: none;
        }

        .total-row {
            display: flex;
            justify-content: space-between;
            padding: 15px 0;
            font-weight: 700;
            font-size: 18px;
            border-top: 2px solid #000;
            margin-top: 10px;
        }

        .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .footer {
            text-align: center;
            margin-top: 30px;
            color: #718096;
            font-size: 13px;
        }

        .badge {
            background: #000;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            color: #fff;
        }

        .status-badge {
            background: #c6f6d5;
            color: #2f855a;
            padding: 2px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }
    </style>
</head>

<body>
    <div class="container">
        <div class="header">
            <h1>
                <%= appName %>
            </h1>
            <p>Official Payment Receipt</p>
        </div>
        <div class="content">
            <div class="receipt-header">
                <h2>Receipt</h2>
                <p style="margin: 5px 0; color: #718096; font-size: 14px;">Transaction ID: <%= transactionId %>
                </p>
            </div>

            <div class="info-grid">
                <div>
                    <h4 style="margin: 0 0 5px 0; color: #718096; text-transform: uppercase; font-size: 12px;">Billed To
                    </h4>
                    <strong>
                        <%= buyerName %>
                    </strong><br>
                    <%= buyerEmail %>
                </div>
                <div style="text-align: right;">
                    <h4 style="margin: 0 0 5px 0; color: #718096; text-transform: uppercase; font-size: 12px;">Date</h4>
                    <%= paymentDate %><br>
                        <span class="status-badge">Paid</span>
                </div>
            </div>

            <div class="order-details">
                <div style="margin-bottom: 15px;">
                    <span class="badge">Order #<%= orderNumber %></span>
                </div>

                <% items.forEach(function(item) { %>
                    <div class="item-row">
                        <div>
                            <div style="font-weight: 600;">
                                <%= item.name %>
                            </div>
                            <div style="font-size: 13px; color: #718096;">Qty: <%= item.quantity %> @ KSh <%=
                                        parseFloat(item.price).toLocaleString() %>
                            </div>
                        </div>
                        <div style="font-weight: 500;">KSh <%= parseFloat(item.subtotal).toLocaleString() %>
                        </div>
                    </div>
                    <% }); %>

                        <div class="total-row">
                            <span>Amount Paid</span>
                            <span>KSh <%= parseFloat(totalAmount).toLocaleString() %></span>
                        </div>

                        <p style="margin: 10px 0 0 0; font-size: 12px; color: #718096; text-align: center;">
                            Payment Method: <%= paymentMethod %>
                        </p>
            </div>

            <div
                style="background: #f0f9ff; border-left: 4px solid #0ea5e9; padding: 15px; border-radius: 4px; margin: 20px 0;">
                <p style="margin: 0; font-size: 14px; color: #0369a1;">
                    <strong>Payment Confirmed.</strong> This serves as your official record of purchase.
                    The seller has been notified to begin fulfillment.
                </p>
            </div>

            <p style="text-align: center; margin-top: 30px;">
                <a href="<%= websiteUrl %>/buyer/orders"
                    style="display: inline-block; padding: 12px 24px; background: #000; color: white; text-decoration: none; border-radius: 6px; font-weight: 500;">View
                    Order Status</a>
            </p>
        </div>
        <div class="footer">
            <p>© <%= new Date().getFullYear() %>
                    <%= appName %>. All rights reserved.</p>
        </div>
    </div>
</body>

</html>