{
  "name": "byblos-backend",
  "version": "1.0.0",
  "description": "Backend for BYBLOS",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "npm run migrate && node src/index.js",
    "dev": "nodemon -r dotenv/config src/index.js",
    "build": "npm install",
    "migrate": "node scripts/migrate.js",
    "migrate:create": "node-pg-migrate create",
    "seed": "node --experimental-json-modules -r dotenv/config scripts/seed-db.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint . --ext .js,.ts",
    "format": "prettier --write \"**/*.{js,ts,json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/byblos.git"
  },
  "keywords": [
    "ecommerce",
    "fashion",
    "nodejs",
    "express",
    "postgresql"
  ],
  "author": "Your Name <your.email@example.com>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/yourusername/byblos/issues"
  },
  "homepage": "https://github.com/yourusername/byblos#readme",
  "dependencies": {
    "@types/uuid": "10.0.0",
    "@whiskeysockets/baileys": "6.6.0",
    "axios": "1.13.2",
    "bcrypt": "6.0.0",
    "canvas": "3.1.1",
    "cloudinary": "1.41.1",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "dotenv": "16.5.0",
    "ejs": "3.1.9",
    "express": "4.18.2",
    "express-rate-limit": "7.5.1",
    "express-xss-sanitizer": "2.0.0",
    "helmet": "8.1.0",
    "hpp": "0.2.3",
    "ioredis": "5.9.2",
    "jsonwebtoken": "9.0.2",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "node-cron": "4.2.1",
    "node-pg-migrate": "6.2.2",
    "nodemailer": "7.0.3",
    "nodemailer-smtp-transport": "2.7.4",
    "pg": "8.16.3",
    "qrcode": "1.5.4",
    "qrcode-terminal": "0.12.0",
    "rate-limit-redis": "4.3.1",
    "uuid": "9.0.1",
    "winston": "3.11.0",
    "winston-daily-rotate-file": "5.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.7",
    "chai": "^5.2.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "mocha": "^11.5.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "es5"
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:import/recommended"
    ],
    "env": {
      "node": true,
      "es2021": true
    },
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "ignorePatterns": [
      "dist",
      "node_modules"
    ]
  }
}